# ============================================================
# GrobsAI Backend - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Application ---
APP_NAME="GrobsAI Backend"
APP_VERSION="1.0.0"
APP_URL="http://localhost:5173"
ENVIRONMENT=development
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
SQLALCHEMY_DATABASE_URL=sqlite:///./grobs.db
# For PostgreSQL (production):
# SQLALCHEMY_DATABASE_URL=postgresql://user:password@localhost:5432/grobsai

# --- Security (REQUIRED - change before deploying) ---
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
REFRESH_SECRET_KEY=your-refresh-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption ---
RESUME_ENCRYPTION_KEY=your-encryption-key-for-resumes
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- AI Provider (choose one) ---
LLM_PROVIDER=google

# Google Gemini (recommended, free tier available)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (alternative)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# Anthropic Claude (alternative)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# HuggingFace (for embeddings)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_PROVIDER="huggingface"

# --- Job APIs (optional) ---
ADZUNA_APP_ID=
ADZUNA_API_KEY=
JOOBLE_API_KEY=
THEIRSTACK_API_KEY=

# --- Vector Database ---
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIR=./chroma_db
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=
# WEAVIATE_URL=
# WEAVIATE_API_KEY=

# --- Celery & Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- File Storage ---
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
SKIP_LLM_PARSING=false

# AWS S3 (optional, for production)
# STORAGE_PROVIDER=s3
# AWS_S3_BUCKET=grobsai-uploads
# AWS_REGION=us-east-1

# --- Email (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@grobsai.com
SMTP_FROM_NAME="GrobsAI"

# --- Stripe (optional, for payments) ---
STRIPE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Monitoring ---
SENTRY_DSN=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./backend.log
